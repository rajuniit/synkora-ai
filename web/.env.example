SENTRY_ORG=
SENTRY_PROJECT=

# Feature Flags
NEXT_PUBLIC_ENABLE_OAUTH=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_COMING_SOON=false
