# Test Environment Configuration (CI)
# Used in GitHub Actions where services run on localhost, not Docker hostnames.
APP_ENV=test
APP_DEBUG=true
SECRET_KEY=test-secret-key-for-ci-testing-only-not-for-production
API_HOST=0.0.0.0
API_PORT=5001

# Database
# postgres service is mapped to port 5439 on the runner.
DB_HOST=localhost
DB_PORT=5439
DB_USERNAME=synkora
DB_PASSWORD=synkora
DB_DATABASE=synkora_test
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=5
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=3600

# Redis (CI: accessible via localhost, not Docker service name)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=test-jwt-secret-key-for-ci-testing-only-not-for-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
JWT_ALGORITHM=HS256

ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# CORS
INNER_CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# File Upload
MAX_UPLOAD_SIZE=15728640
INNER_ALLOWED_EXTENSIONS=txt,pdf,docx,md,html
