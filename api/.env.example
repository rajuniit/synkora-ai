# Application
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=5001

# Database
DB_HOST=db
DB_PORT=5432
DB_USERNAME=synkora
DB_PASSWORD=synkora
DB_DATABASE=synkora
DB_CHARSET=
DB_EXTRAS=
SQLALCHEMY_DATABASE_URI_SCHEME=postgresql
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_USE_LIFO=false
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
# JWT_ISSUER and JWT_AUDIENCE must match across all services that validate tokens
# JWT_ISSUER=api
# JWT_AUDIENCE=app

# Encryption (for OAuth tokens and API keys)
# Generate a new key with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload
MAX_UPLOAD_SIZE=15728640  # 15MB in bytes
ALLOWED_EXTENSIONS=txt,pdf,docx,md,html

# LLM Providers (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Vector Database Configuration
# Supported types: CHROMA (default), QDRANT, weaviate, milvus
VECTOR_STORE=CHROMA

# ChromaDB (Default - Recommended)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_AUTH_PROVIDER=
CHROMA_AUTH_CREDENTIALS=

# Qdrant (Optional)
QDRANT_URL=
QDRANT_API_KEY=

# Pinecone (Optional)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_CLOUD=aws

# Weaviate (Optional)
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Milvus (Optional)
MILVUS_HOST=
MILVUS_PORT=
MILVUS_USER=
MILVUS_PASSWORD=

# Monitoring (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Prometheus metrics endpoint security (REQUIRED in production)
# Prometheus scrapers should pass: Authorization: Bearer <token>
# If not set, the /metrics endpoint is blocked in production.
METRICS_AUTH_TOKEN=

# Audit log HMAC chain secret (RECOMMENDED in production)
# Makes the audit log tamper-evident — any deletion or modification breaks the chain.
# Generate with: openssl rand -hex 32
AUDIT_CHAIN_SECRET=


# Audit log retention (days). Default 365 satisfies SOC 2 / PCI DSS 1-year requirements.
AUDIT_LOG_RETENTION_DAYS=365


# Data retention policies (days). Defaults match common compliance baselines.
CONVERSATION_RETENTION_DAYS=365
MESSAGE_RETENTION_DAYS=365
FILE_RETENTION_DAYS=90


# SIEM webhook integration (optional)
# When set, every audit log entry is forwarded as a JSON POST to this URL.
SIEM_WEBHOOK_URL=
# Optional HMAC-SHA256 signing secret — adds X-SIEM-Signature header to each POST
SIEM_WEBHOOK_SECRET=


# Session security
# Maximum total session age regardless of activity (hours). Forces re-login after this period.
JWT_MAX_SESSION_AGE_HOURS=12


# HaveIBeenPwned breach check on registration and password reset (k-anonymity, no API key needed)
HIBP_CHECK_ENABLED=true


# Dormant account auto-disable threshold (days inactive before account is set to INACTIVE)
DORMANT_ACCOUNT_DAYS=90


# LLM output hard ceiling — prevents token-padding / data exfiltration via huge responses
PLATFORM_MAX_TOKENS_PER_RESPONSE=32000


# Comma-separated list of domains the web-fetch agent tool cannot POST/GET to
# Example: AGENT_BLOCKED_DOMAINS=internal.corp.com,metadata.google.internal
AGENT_BLOCKED_DOMAINS=


# Set to true to hide real model name/provider from public cross-tenant agent responses
HIDE_MODEL_INFO_IN_PUBLIC=false


# Override Redis TLS enforcement in production (set true ONLY for local testing)
ALLOW_INSECURE_REDIS=false


# Contact form destination
CONTACT_EMAIL=hello@localhost

# App URL (used in emails, OAuth redirects, widget branding)
APP_BASE_URL=http://localhost:3005
SUPPORT_EMAIL=support@localhost
DOCS_URL=

# AWS S3 Storage (for document storage)
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: Custom S3 endpoint for MinIO or other S3-compatible services
# AWS_ENDPOINT_URL=http://minio:9000
# Optional: Public endpoint for browser access to presigned URLs (different from internal endpoint in Docker)
# AWS_PUBLIC_ENDPOINT_URL=http://localhost:9000

# LLM timeout for non-streaming function-calling calls (seconds). Large contexts need more time.
LLM_FUNCTION_CALLING_TIMEOUT=600

# Langfuse Observability (Self-Hosted)
# After starting docker-compose, get your keys from http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_ENABLED=true
LANGFUSE_SAMPLE_RATE=1.0

# Platform OAuth Apps (Optional)
# These are Synkora-provided OAuth integrations available to all tenants
# Tenants can use these without setting up their own OAuth credentials

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack OAuth App
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitLab OAuth App (gitlab.com)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Zoom OAuth App
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Gmail OAuth App (Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Billing (Required if using Paddle)
# Set this to your Paddle webhook signing secret - without it, webhooks are rejected
PADDLE_WEBHOOK_SECRET=

# Agent git operations
GIT_AGENT_EMAIL=agent@localhost
GIT_AGENT_NAME=AI Agent

# Custom Domain Configuration
# Platform domain for custom agent chat pages
LOAD_TEST_MODE=false

# AWS Lambda Execution Backend (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_ARN=        # ARN of the Lambda function to invoke for agent tasks
AWS_LAMBDA_ROLE_ARN=            # IAM role ARN (for function creation reference)
LAMBDA_INVOCATION_SECRET=       # HMAC signing key for Lambda invocation payloads


# GCP Cloud Run Execution Backend (optional)
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=       # base64-encoded service account JSON
GCP_REGION=us-central1
CLOUD_RUN_JOB_NAME=             # Name of the Cloud Run Job for agent tasks
CLOUD_RUN_INVOCATION_SECRET=    # HMAC signing key for Cloud Run invocation payloads


# DigitalOcean Functions Execution Backend (optional — recommended for DKS deployments)
DO_API_TOKEN=                   # DigitalOcean personal access token (write scope)
DO_FUNCTIONS_ENDPOINT=          # Full HTTPS URL: https://faas-{region}.doserverless.co/api/v1/web/{ns}/{pkg}/{fn}
DO_FUNCTIONS_INVOCATION_SECRET= # HMAC signing key for DO Functions invocation payloads


# Set this to "true" inside Lambda / Cloud Run / DO Functions containers ONLY.
# Prevents the task executor from re-dispatching to the external backend (infinite loop guard).
# DO NOT set this on the Celery worker.
SYNKORA_DIRECT_EXECUTION=false